{
  "name": "@pound79/specproof-traceability",
  "version": "0.2.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "Framework-agnostic spec<->impl<->feature traceability manifest and SHA-256 drift detection for BDD behavior tests.",
  "license": "MIT",
  "author": "Pound79",
  "keywords": [
    "bdd",
    "traceability",
    "drift",
    "gherkin",
    "e2e"
  ],
  "homepage": "https://github.com/Pound79/specproof/tree/main/packages/traceability",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pound79/specproof.git",
    "directory": "packages/traceability"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "specproof-check": "dist/cli-check.js",
    "specproof-update": "dist/cli-update.js",
    "specproof-list": "dist/cli-list.js",
    "specproof-stats": "dist/cli-stats.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && node -e \"const fs=require('node:fs');['dist/cli-check.js','dist/cli-update.js','dist/cli-list.js','dist/cli-stats.js'].forEach((f)=>fs.chmodSync(f, 0o755));\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "tsx src/cli-check.ts",
    "update": "tsx src/cli-update.ts",
    "list": "tsx src/cli-list.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
