node_modules/
dist/
*.log
*.tsbuildinfo
*.orig
.DS_Store
coverage/

# Editor / tooling
.vscode/
.idea/
*.swp

# Agent / assistant local state
.serena/
# Ignore personal Claude Code config, but track shared project skills.
# (`!.claude/` first re-includes the dir even when a global gitignore excludes it.)
!.claude/
.claude/*
!.claude/skills/

# Secrets — never commit (templates/**/.env.example is the tracked template)
.env
.env.local
.env.*.local

# Local-only drafts (personal notes, slides, etc.) — never committed
*.local.md

# Flutter generated files (templates/flutter/ is a scaffold, not a project)
**/.dart_tool/
templates/**/.flutter-plugins
templates/**/.flutter-plugins-dependencies
templates/**/pubspec.lock

# Transient copy created by cli's prepack (templates are bundled into the
# published tarball, then removed by postpack).
cli/templates/
