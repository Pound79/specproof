{
  "name": "specproof",
  "private": true,
  "version": "0.0.0",
  "description": "Framework-agnostic AI-development quality governance kit: a traceability engine + AI agent skills (SKILL.md standard) + per-framework BDD scaffolds (playwright web, Flutter flutter_gherkin + Patrol).",
  "type": "module",
  "license": "MIT",
  "author": "Pound79",
  "homepage": "https://github.com/Pound79/specproof",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pound79/specproof.git"
  },
  "workspaces": [
    "packages/*",
    "cli"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check:versions": "node scripts/check-versions.mjs",
    "release": "bash scripts/release.sh"
  }
}
