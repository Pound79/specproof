# .env.example — copy to .env and fill in real values (never commit .env)
#
# All variables are optional at definition time; the runner will fall back to
# defaults (e.g. http://localhost:5173) when a value is absent.
# See specproof.config.yaml for the logical names that map to these variables.

# ---------------------------------------------------------------------------
# Application under test
# ---------------------------------------------------------------------------

# Base URL of the running application.
# E2E_BASE_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Regular user credentials
# ---------------------------------------------------------------------------

# E2E_USERNAME=user@example.com
# E2E_PASSWORD=ChangeMe1!
# E2E_NEW_PASSWORD=ChangeMe2!

# ---------------------------------------------------------------------------
# Admin user credentials (optional — skip authed-admin project when absent)
# ---------------------------------------------------------------------------

# E2E_ADMIN_USERNAME=admin@example.com
# E2E_ADMIN_PASSWORD=AdminPass1!
# E2E_ADMIN_NEW_PASSWORD=AdminPass2!

# ---------------------------------------------------------------------------
# Web server (optional — set "true" to let Playwright start the dev server)
# ---------------------------------------------------------------------------

# E2E_START_WEB_SERVER=false
