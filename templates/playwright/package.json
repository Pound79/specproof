{
  "name": "e2e",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
    "test:smoke": "bddgen && playwright test --grep-invert @slow",
    "test:headed": "bddgen && playwright test --headed",
    "test:ui": "bddgen && playwright test --ui",
    "report": "playwright show-report",
    "lint": "echo 'no linter configured — add eslint/prettier in your project'",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright-bdd": "^9.2.0",
    "dotenv": "^17.4.2",
    "yaml": "^2.6.1",
    "typescript": "^6.0.3",
    "@types/node": "^22.10.5"
  }
}
