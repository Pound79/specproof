{
  "name": "@pound79/specproof",
  "version": "0.2.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "Scaffolder CLI for specproof — keeps AI-written E2E tests honest. `specproof init` drops a config-driven behavior-test scaffold (Playwright / Flutter) plus a PR drift-check workflow into your repo.",
  "license": "MIT",
  "author": "Pound79",
  "homepage": "https://github.com/Pound79/specproof/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pound79/specproof.git",
    "directory": "cli"
  },
  "bin": {
    "specproof": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node -e \"const fs=require('node:fs');fs.rmSync('templates',{recursive:true,force:true});fs.rmSync('skills',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
